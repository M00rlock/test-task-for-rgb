{
  "name": "rgb-test-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:backend": "npm run dev --prefix backend",
    "db:up": "node scripts/ensure-postgres.mjs",
    "db:down": "node scripts/stop-postgres.mjs",
    "db:migrate": "npm run prisma:migrate:deploy --prefix backend",
    "db:seed": "npm run prisma:seed --prefix backend",
    "db:setup": "node scripts/ensure-backend-env.mjs && npm run db:up && node scripts/wait-for-port.mjs 127.0.0.1 5432 60000 && npm run db:migrate && npm run db:seed",
    "dev:all": "npm run db:setup && concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:backend\"",
    "dev:stop": "node scripts/stop-dev.mjs",
    "build": "next build",
    "build:backend": "npm run build --prefix backend",
    "start": "next start",
    "start:backend": "npm run start --prefix backend",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.510.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.0.15",
    "@types/react-dom": "^19.0.10",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
